# Вы можете создать такую диаграмму в R:
library(DiagrammeR)

create_architecture_diagram <- function() {
  grViz("
digraph architecture {
  graph [layout = dot, rankdir = TB]
  
  node [shape = rectangle, style = filled]
  
  // Уровни архитектуры
  subgraph cluster_ui {
    label = 'Presentation Layer (UI)';
    style = filled;
    color = lightblue;
    
    LoginUI [label = 'Login UI\nuiOutput(\\\\\"auth_forms\\\\\")']
    MainUI [label = 'Main UI\nuiOutput(\\\\\"main_interface\\\\\")'] 
    AppUI [label = 'Application UI\nuiOutput(\\\\\"application_form\\\\\")']
  }
  
  subgraph cluster_controller {
    label = 'Controller Layer (Server)';
    style = filled;
    color = lightgreen;
    
    AuthController [label = 'Auth Controller\nobserveEvent(input$login_btn)']
    RegController [label = 'Registration Controller\nobserveEvent(input$register_btn)']
    AppController [label = 'Application Controller\nobserveEvent(input$submit_app_btn)']
  }
  
  subgraph cluster_service {
    label = 'Business Logic Layer (R/)';
    style = filled;
    color = lightyellow;
    
    AuthService [label = 'Auth Service\nauth.R functions']
    ConferenceService [label = 'Conference Service\nlogic.R functions']
    DatabaseService [label = 'Database Service\ndb_functions.R']
  }
  
  subgraph cluster_data {
    label = 'Data Access Layer';
    style = filled;
    color = lightpink;
    
    Database [label = 'SQLite Database\nusers, conferences, applications']
  }
  
  // Связи
  LoginUI -> AuthController
  MainUI -> RegController
  AppUI -> AppController
  
  AuthController -> AuthService
  RegController -> AuthService
  AppController -> ConferenceService
  
  AuthService -> DatabaseService
  ConferenceService -> DatabaseService
  
  DatabaseService -> Database
}
")
}