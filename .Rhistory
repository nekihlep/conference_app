data<- read.csv("C:/Users/Admin/Desktop/os_data.csv")
data$mean_share <- rowMeans(data[, 2:13])
sorted_data <- data[order(-data$mean_share), c("OS", "mean_share")]
top_3_os <- head(sorted_data, 3)
top_3_os
top_os_names <- top_3_os$OS
windows_data <- as.numeric(data[data$OS == top_os_names[1], 2:13])
macos_data <- as.numeric(data[data$OS == top_os_names[2], 2:13])
linux_data <- as.numeric(data[data$OS == top_os_names[3], 2:13])
ts_windows <- ts(windows_data, start = c(2023, 1), frequency = 12)
ts_macos <- ts(macos_data, start = c(2023, 1), frequency = 12)
ts_linux <- ts(linux_data, start = c(2023, 1), frequency = 12)
# Строим первый график (Windows)
plot(ts_windows,
main = "Динамика использования операционных систем",
xlab = "Дата",
ylab = "Доля рынка (%)",
col = "blue",
lwd = 2,
lty = 1,
pch = 16,
cex = 1.2,
ylim = range(c(ts_windows, ts_macos, ts_linux)) * c(0.9, 1.1))
# Добавляем macOS
lines(ts_macos,
col = "red",
lwd = 2,
lty = 2,
pch = 17,
cex = 1.2,
type = "o")
# Добавляем Linux
lines(ts_linux,
col = "green",
lwd = 2,
lty = 3,
pch = 18,
cex = 1.5,
type = "o")
legend("topright",
legend = top_os_names,
col = c("blue", "red", "green"),
lwd = 2,
lty = c(1, 2, 3),
pch = c(16, 17, 18),
cex = 0.8)
data(EuStockMarkets)
n_days <- 730
bitcoin_data <- data.frame(
Date = seq.Date(from = as.Date("2022-01-01"),
by = "day",
length.out = n_days),
Price = as.numeric(EuStockMarkets[1:n_days, 1]) * 20
)
head(bitcoin_data)
tail(bitcoin_data)
par(mfrow = c(1, 2))
plot(bitcoin_data$Date, bitcoin_data$Price, type = "l",
col = "red", lwd = 2,
main = "Динамика курса Биткоина",
xlab = "Дата", ylab = "Цена ($)")
bp<- boxplot(bitcoin_data$Price,
main = "Распределение цен Биткоина",
ylab = "Цена ($)")
print(round(mean(bitcoin_data$Price)),2)
bp$out  # выбросы
print(bp$stats) # нижний_ус  Q1  медиана  Q3  верхний_ус
text(x = 0.7, y = bp$stats[1], labels = round(bp$stats[1], 1), col = "red",cex = 0.6, font = 3)
text(x = 0.7, y = bp$stats[2], labels = round(bp$stats[2], 1), col = "blue",cex = 0.6, font = 3)
text(x = 0.7, y = bp$stats[3], labels = round(bp$stats[3], 1), col = "green",cex = 0.6, font = 3)
text(x = 0.7, y = bp$stats[4], labels = round(bp$stats[4], 1), col = "blue",cex = 0.6, font = 3)
text(x = 0.7, y = bp$stats[5], labels = round(bp$stats[5], 1), col = "red",cex = 0.6, font = 3)
