source("R/db_functions.R")
conn <- get_db_connection()
dbExecute(conn, "ALTER TABLE applications ADD COLUMN applied_at DATETIME DEFAULT CURRENT_TIMESTAMP")
dbDisconnect(conn)
cat("✅ Готово! Колонка applied_at добавлена.\n")
source("R/db_functions.R")
conn <- get_db_connection()
dbListFields(conn, "applications")  # Увидите applied_at в списке
dbDisconnect(conn)
runApp()
