# Подключаемся к базе
conn <- DBI::dbConnect(RSQLite::SQLite(), "data/database.sqlite")
# 1. Сначала посмотрим текущие конференции и их ID
conferences <- DBI::dbGetQuery(conn, "SELECT conference_id, title, date FROM conferences")
print(conferences)
# 2. Добавляем тестовые заявки для конференций с разной заполняемостью
# Конференция 1 (ID 1) - 90% заполнена (180 из 200)
for(i in 1:180) {
DBI::dbExecute(conn,
"INSERT INTO applications (user_id, conference_id, participation_type, status)
VALUES (2, 1, 'listener', 'approved')")
}
# Конференция 2 (ID 2) - 60% заполнена (90 из 150)
for(i in 1:90) {
DBI::dbExecute(conn,
"INSERT INTO applications (user_id, conference_id, participation_type, status)
VALUES (2, 2, 'listener', 'approved')")
}
# Конференция 3 (ID 3) - 30% заполнена (9 из 30)
for(i in 1:9) {
DBI::dbExecute(conn,
"INSERT INTO applications (user_id, conference_id, participation_type, status)
VALUES (2, 3, 'listener', 'approved')")
}
# Конференция 4 (ID 4) - 95% заполнена (285 из 300)
for(i in 1:285) {
DBI::dbExecute(conn,
"INSERT INTO applications (user_id, conference_id, participation_type, status)
VALUES (2, 4, 'listener', 'approved')")
}
# Конференция 5 (ID 5) - 100% заполнена (4 из 4)
for(i in 1:4) {
DBI::dbExecute(conn,
"INSERT INTO applications (user_id, conference_id, participation_type, status)
VALUES (2, 5, 'listener', 'approved')")
}
# Конференция 6 (ID 6) - 25% заполнена (5 из 20)
for(i in 1:5) {
DBI::dbExecute(conn,
"INSERT INTO applications (user_id, conference_id, participation_type, status)
VALUES (2, 6, 'listener', 'approved')")
}
# Конференция 7 (ID 7) - 75% заполнена (75 из 100)
for(i in 1:75) {
DBI::dbExecute(conn,
"INSERT INTO applications (user_id, conference_id, participation_type, status)
VALUES (2, 7, 'listener', 'approved')")
}
# 3. Проверяем результат
result <- DBI::dbGetQuery(conn, "
SELECT
c.conference_id,
c.title,
c.max_participants,
COUNT(a.application_id) as total_applications,
COUNT(CASE WHEN a.status = 'approved' THEN 1 END) as approved_count,
ROUND(COUNT(CASE WHEN a.status = 'approved' THEN 1 END) * 100.0 / c.max_participants, 1) as fill_percentage
FROM conferences c
LEFT JOIN applications a ON c.conference_id = a.conference_id
GROUP BY c.conference_id, c.title, c.max_participants
ORDER BY c.conference_id
")
print(result)
# Закрываем соединение
DBI::dbDisconnect(conn)
cat("✅ Тестовые данные добавлены! Теперь можно тестировать графики.\n")
runApp()
# Подключаемся к базе
conn <- DBI::dbConnect(RSQLite::SQLite(), "data/database.sqlite")
# 1. Сначала посмотрим сколько всего заявок
total_apps <- DBI::dbGetQuery(conn, "SELECT COUNT(*) as total FROM applications")$total
cat("Всего заявок:", total_apps, "\n")
# 2. Обновляем статусы существующих заявок для баланса
# Первые 15 заявок делаем на рассмотрение
DBI::dbExecute(conn, "
UPDATE applications
SET status = 'pending'
WHERE application_id IN (
SELECT application_id FROM applications
ORDER BY application_id
LIMIT 15
)
")
# Следующие 10 заявок делаем отклоненными
DBI::dbExecute(conn, "
UPDATE applications
SET status = 'rejected'
WHERE application_id IN (
SELECT application_id FROM applications
WHERE status != 'pending'
ORDER BY application_id
LIMIT 10
)
")
# 3. Проверяем результат
status_stats <- DBI::dbGetQuery(conn, "
SELECT
status,
COUNT(*) as count,
ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM applications), 1) as percentage
FROM applications
GROUP BY status
ORDER BY status
")
print(status_stats)
# Закрываем соединение
DBI::dbDisconnect(conn)
cat("✅ Статусы заявок сбалансированы!\n")
runApp()
# Добавляем колонку один раз
add_created_at_to_applications <- function() {
conn <- get_db_connection()
tryCatch({
# Добавляем колонку created_at
dbExecute(conn, "
ALTER TABLE applications ADD COLUMN created_at DATETIME DEFAULT CURRENT_TIMESTAMP
")
# Для существующих записей проставляем текущую дату
dbExecute(conn, "
UPDATE applications SET created_at = datetime('now')
WHERE created_at IS NULL
")
cat("✅ Колонка created_at добавлена! Теперь все новые заявки будут автоматически получать временную метку.\n")
}, error = function(e) {
cat("ℹ️ Колонка уже существует:", e$message, "\n")
}, finally = {
dbDisconnect(conn)
})
}
# Вызовите в консоли:
# add_created_at_to_applications()
# Выполняйте построчно в консоли RStudio:
# 1. Подключаемся к базе
conn <- DBI::dbConnect(RSQLite::SQLite(), "data/database.sqlite")
# 2. Добавляем колонку created_at
DBI::dbExecute(conn, "
ALTER TABLE applications ADD COLUMN created_at DATETIME DEFAULT CURRENT_TIMESTAMP
")
# Выполните в консоли:
conn <- DBI::dbConnect(RSQLite::SQLite(), "data/database.sqlite")
# 1. Добавляем колонку
DBI::dbExecute(conn, "
ALTER TABLE applications ADD COLUMN created_at DATETIME
")
# 2. Создаем триггер который автоматически ставит дату при ВСТАВКЕ новой заявки
DBI::dbExecute(conn, "
CREATE TRIGGER IF NOT EXISTS set_application_timestamp
AFTER INSERT ON applications
FOR EACH ROW
BEGIN
UPDATE applications SET created_at = datetime('now') WHERE application_id = NEW.application_id;
END
")
# 3. Для существующих записей проставляем дату
DBI::dbExecute(conn, "
UPDATE applications SET created_at = datetime('now')
WHERE created_at IS NULL
")
# 4. Проверяем
result <- DBI::dbGetQuery(conn, "SELECT application_id, created_at FROM applications LIMIT 5")
print(result)
DBI::dbDisconnect(conn)
cat("✅ Триггер создан! Теперь ВСЕ новые заявки автоматически получат временную метку.\n")
# Более реалистичное распределение с пиками активности
conn <- DBI::dbConnect(RSQLite::SQLite(), "data/database.sqlite")
# Получаем ID всех заявок
app_ids <- DBI::dbGetQuery(conn, "SELECT application_id FROM applications ORDER BY application_id")$application_id
total_apps <- length(app_ids)
# Создаем распределение с пиками
dates_with_weights <- data.frame(
date = seq.Date(from = Sys.Date() - 29, to = Sys.Date(), by = "day"),
weight = c(1, 1, 3, 2, 1, 1, 1,   # неделя 1
2, 1, 4, 3, 1, 2, 1,   # неделя 2 (пик в среду)
1, 1, 1, 2, 1, 5, 3,   # неделя 3 (пик в субботу)
1, 2, 1, 3, 4, 2, 1,   # неделя 4
1, 1)                   # последние 2 дня
)
# Нормализуем веса
dates_with_weights$prob <- dates_with_weights$weight / sum(dates_with_weights$weight)
# Распределяем заявки согласно весам
for(i in seq_along(app_ids)) {
# Выбираем дату согласно распределению
selected_date <- sample(dates_with_weights$date, size = 1, prob = dates_with_weights$prob)
# Случайное время
random_hour <- sample(9:20, 1)
random_minute <- sample(0:59, 1)
random_second <- sample(0:59, 1)
random_datetime <- paste0(selected_date, " ",
sprintf("%02d:%02d:%02d", random_hour, random_minute, random_second))
DBI::dbExecute(conn,
"UPDATE applications SET created_at = ? WHERE application_id = ?",
params = list(random_datetime, app_ids[i]))
}
# Проверяем результат
result <- DBI::dbGetQuery(conn, "
SELECT
DATE(created_at) as date,
COUNT(*) as count,
COUNT(*) * 100.0 / (SELECT COUNT(*) FROM applications) as percent
FROM applications
GROUP BY DATE(created_at)
ORDER BY date
")
print("Реальное распределение:")
print(result)
DBI::dbDisconnect(conn)
cat("✅ Реалистичные даты установлены! График покажет пики активности.\n")
runApp()
runApp()
runApp()
runApp()
runApp()
