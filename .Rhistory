# Проверка БД
source("R/db_functions.R")
conn <- get_db_connection()
# Какие таблицы есть в БД?
cat("Таблицы в БД:", paste(dbListTables(conn), collapse = ", "), "\n")
# Проверяем таблицу conferences
if ("conferences" %in% dbListTables(conn)) {
conferences <- dbGetQuery(conn, "SELECT * FROM conferences")
cat("Конференций в БД:", nrow(conferences), "\n")
if (nrow(conferences) > 0) {
print(conferences)
} else {
cat("Таблица conferences пустая!\n")
}
} else {
cat("Таблица conferences не существует!\n")
}
dbDisconnect(conn)
