source("R/db_functions.R")
conn <- get_db_connection()
# 1. Создаем временную таблицу без колонки qualification_file
dbExecute(conn, "
CREATE TABLE applications_new (
application_id INTEGER PRIMARY KEY AUTOINCREMENT,
user_id INTEGER NOT NULL,
conference_id INTEGER NOT NULL,
participation_type TEXT NOT NULL CHECK(participation_type IN ('speaker', 'listener')),
topic TEXT,
status TEXT NOT NULL DEFAULT 'pending' CHECK(status IN ('pending', 'approved', 'rejected')),
FOREIGN KEY(user_id) REFERENCES users(user_id),
FOREIGN KEY(conference_id) REFERENCES conferences(conference_id)
)
")
# 2. Копируем данные из старой таблицы в новую
dbExecute(conn, "
INSERT INTO applications_new (application_id, user_id, conference_id, participation_type, topic, status)
SELECT application_id, user_id, conference_id, participation_type, topic, status
FROM applications
")
# 3. Удаляем старую таблицу
dbExecute(conn, "DROP TABLE applications")
# 4. Переименовываем новую таблицу
dbExecute(conn, "ALTER TABLE applications_new RENAME TO applications")
dbDisconnect(conn)
cat("✅ Колонка qualification_file успешно удалена!\n")
# Проверь структуру таблицы
conn <- get_db_connection()
columns <- dbGetQuery(conn, "PRAGMA table_info(applications)")
print(columns)
dbDisconnect(conn)
runApp()
