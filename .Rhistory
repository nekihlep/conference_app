X <- rnorm(100,mean=167,sd=20)
hist(X, probability = TRUE,
col = "lightblue",
main = "Плотность распределения случайного вектора X",
xlab = "Значения X",
ylab = "Плотность вероятности",
ylim = c(0, 0.03))
lines(density(X),
col = "red",
lwd = 2)
lines(density(X, bw = 0.5),
col = "blue",
lwd = 2)
legend("topright",
legend = c("Гистограмма", "Сглаженная плотность", "Несглаженная плотность"),
col = c("lightblue", "red", "blue"),
lwd = c(10, 2, 2),
lty = c(1, 1, 1))
library(MASS)
mu <- c(0, 0)
Sigma <- matrix(c(1, 0.8, 0.8, 1), nrow = 2)
set.seed(123)
bivn <- mvrnorm(4000,mu,Sigma)
head(bivn, 5)
bivn.kde <- kde2d(bivn[,1], bivn[,2], n = 50)
par(mfrow = c(1, 2))
image(bivn.kde,
main = "Двумерная плотность вероятности",
xlab = "Ось X",
ylab = "Ось Y")
contour(bivn.kde,
add = TRUE,
)
persp(bivn.kde,
main = "Трёхмерное представление плотности",
xlab = "X", ylab = "Y", zlab = "Плотность")
par(mfrow = c(1, 1))
