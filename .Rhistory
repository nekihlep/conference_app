library(DiagrammeR)
install.packages("DiagrammeR")
library(DiagrammeR)
show_mermaid_in_viewer <- function() {
mermaid_code <- "
graph TD
A[users] --> B[conferences]
A --> C[applications]
B --> C
C --> D[application_files]
style A fill:#lightblue
style B fill:#lightgreen
style C fill:#lightyellow
style D fill:#lightcoral
"
mermaid(mermaid_code)
}
# Запусти эту функцию - открое
library(DiagrammeR)
show_mermaid_in_viewer <- function() {
mermaid_code <- "
graph TD
A[users] --> B[conferences]
A --> C[applications]
B --> C
C --> D[application_files]
style A fill:#lightblue
style B fill:#lightgreen
style C fill:#lightyellow
style D fill:#lightcoral
"
mermaid(mermaid_code)
}
# Запусти эту функцию - откроется во Viewer
show_mermaid_in_viewer()
