# database_schema.R
library(DBI)
library(RSQLite)
print_logical_schema <- function() {
cat("
=== ЛОГИЧЕСКАЯ МОДЕЛЬ БАЗЫ ДАННЫХ КОНФЕРЕНЦИЙ ===
users (Пользователи)
├── user_id (PK)
├── username
├── password_hash
└── role (admin/user)
conferences (Конференции)
├── conference_id (PK)
├── title
├── status
└── created_by (FK → users)
applications (Заявки)
├── application_id (PK)
├── user_id (FK → users)
├── conference_id (FK → conferences)
├── participation_type
└── status
application_files (Файлы заявок)
├── file_id (PK)
├── application_id (FK → applications)
└── file_name
СВЯЗИ:
users (1) → (N) conferences
users (1) → (N) applications
conferences (1) → (N) applications
applications (1) → (N) application_files
")
}
generate_mermaid_diagram <- function() {
mermaid_code <- '
erDiagram
users {
INTEGER user_id PK
TEXT username UK
TEXT password_hash
TEXT role
}
conferences {
INTEGER conference_id PK
TEXT title
TEXT status
INTEGER created_by FK
}
applications {
INTEGER application_id PK
INTEGER user_id FK
INTEGER conference_id FK
TEXT participation_type
TEXT status
}
application_files {
INTEGER file_id PK
INTEGER application_id FK
TEXT file_name
}
users ||--o{ conferences : "created_by"
users ||--o{ applications : ""
conferences ||--o{ applications : ""
applications ||--o{ application_files : ""
'
cat(mermaid_code)
return(mermaid_code)
}
# Запуск функций
print_logical_schema()
mermaid_code <- generate_mermaid_diagram()
